local function stripHtml(text)
	return text
		:gsub("<[^>]+>", "")
		:gsub("</[^>]+>", "")
		:gsub("&lt;", "<")
		:gsub("&gt;", ">")
		:gsub("&amp;", "&")
end

local function setupSystemChatLogger()
	if game.PlaceId ~= 118549209655225 then return end
	local myDisplayName = player.DisplayName
	local myUsername    = player.Name

	local function onSystemMessage(msg)
		if msg.TextSource ~= nil then return end
		local raw   = msg.Text or ""
		local clean = stripHtml(raw)
		local lower = clean:lower()

		if not (string.find(lower, myDisplayName:lower()) or string.find(lower, myUsername:lower())) then return end
		if not string.find(lower, "has obtained") then return end

		local itemName = clean:match("has obtained (.+)") or ""
		itemName = itemName:gsub("%s+$", "")

		local embed = {
			title     = "🎁  ได้รับไอเทมใหม่!",
			color     = 16766720,
			timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z"),
			thumbnail = {
				url = "https://www.roblox.com/headshot-thumbnail/image?userId="
					.. player.UserId .. "&width=420&height=420&format=png"
			},
			footer = { text = "Item Logger  •  Valdrayn Script" },
			fields = {
				{ name = "👤  ผู้เล่น",         value = myDisplayName .. "  `(" .. myUsername .. ")`",                  inline = true  },
				{ name = "🎀  ไอเทม",            value = itemName ~= "" and ("**" .. itemName .. "**") or "ไม่ทราบชื่อ", inline = true  },
				{ name = "🕐  เวลา",             value = os.date("%H:%M:%S", os.time()),                                 inline = true  },
				{ name = "📍  Server",           value = "`" .. tostring(game.PlaceId) .. "`",                           inline = true  },
				{ name = "👥  ผู้เล่นในเซิร์ฟ", value = tostring(#Players:GetPlayers()) .. " คน",                      inline = true  },
				{ name = "💬  System Message",   value = "```" .. clean .. "```",                                        inline = false },
			}
		}

		pcall(function()
			request({
				Url     = WEBHOOK_URL,
				Method  = "POST",
				Headers = { ["Content-Type"] = "application/json" },
				Body    = HttpService:JSONEncode({ embeds = { embed } })
			})
		end)
	end

	task.spawn(function()
		local textChannels = TextChatService:FindFirstChild("TextChannels")
		if textChannels then
			for _, ch in pairs(textChannels:GetChildren()) do
				if ch:IsA("TextChannel") then
					ch.MessageReceived:Connect(onSystemMessage)
				end
			end
		end
		TextChatService.MessageReceived:Connect(onSystemMessage)
	end)
end

setupSystemChatLogger()

